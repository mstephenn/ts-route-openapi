{
  "name": "ts-route-openapi",
  "version": "0.0.0",
  "description": "Generate OpenAPI 3.0.3 specs from TypeScript route→controller code via static analysis (ts-morph).",
  "type": "module",
  "bin": { "ts-route-openapi": "dist/cli.js" },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "cac": "^7.0.0",
    "ts-morph": "^28.0.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
